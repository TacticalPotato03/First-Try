---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Projects | Travis Damgaard Campbell"
  description="Things I've built, shipped, and documented — from first principles."
>
  <div class="container">
    <section class="hero">
      <p class="hero-eyebrow">Travis Damgaard Campbell</p>
      <h1 class="hero-title">Projects</h1>
      <p class="hero-subtitle">Things I've built, shipped, and documented — from first principles.</p>
    </section>

    <section>
      <p class="posts-section-label">All Projects</p>
      {projects.length === 0 ? (
        <p style="color: var(--color-text-muted); font-style: italic;">No projects yet. Check back soon.</p>
      ) : (
        <ul class="post-list">
          {projects.map((project) => (
  <li class="post-item">
    <a href={`/projects/${project.slug}/`} class="post-item-link">
      <div class="post-item-content">
        <div class="post-item-title">{project.data.title}</div>
        {project.data.description && (
          <div class="post-item-description">{project.data.description}</div>
        )}
        <div class="post-item-date">{formatDate(project.data.date)}</div>
      </div>
    </a>
  </li>
))}
        </ul>
      )}
    </section>
  </div>
</BaseLayout>
